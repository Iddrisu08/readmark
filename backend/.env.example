# ReadMark — Environment Variables
# Copy this to .env and fill in your values

# A random secret key for JWT tokens (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret-in-production

# Database (SQLite is the default — no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./readmark.db

# CORS — comma-separated origins allowed to access the API
# Use * for development, specify exact origins for production
ALLOWED_ORIGINS=*

# Google OAuth (optional — leave blank to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Debug mode (set to false in production)
DEBUG=false

# ── AI summarization (optional) ──────────────────────────────────
# Leave ANTHROPIC_API_KEY blank to disable the AI feature entirely.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001
AI_MAX_TOKENS=400
